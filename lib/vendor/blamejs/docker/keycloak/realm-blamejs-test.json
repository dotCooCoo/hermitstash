{
  "realm": "blamejs-test",
  "enabled": true,
  "sslRequired": "none",
  "registrationAllowed": false,
  "loginWithEmailAllowed": true,
  "duplicateEmailsAllowed": false,
  "resetPasswordAllowed": false,
  "editUsernameAllowed": false,
  "bruteForceProtected": false,
  "accessTokenLifespan": 600,
  "refreshTokenMaxReuse": 0,
  "ssoSessionIdleTimeout": 1800,
  "ssoSessionMaxLifespan": 36000,

  "users": [
    {
      "username": "alice",
      "email": "alice@example.com",
      "firstName": "Alice",
      "lastName": "Tester",
      "enabled": true,
      "emailVerified": true,
      "credentials": [
        { "type": "password", "value": "blamejs-test-password", "temporary": false }
      ],
      "realmRoles": ["default-roles-blamejs-test"]
    }
  ],

  "clients": [
    {
      "clientId": "blamejs-rp-oidc",
      "name": "blamejs OIDC RP (integration test)",
      "enabled": true,
      "protocol": "openid-connect",
      "publicClient": false,
      "secret": "blamejs-test-rp-secret",
      "standardFlowEnabled": true,
      "directAccessGrantsEnabled": true,
      "serviceAccountsEnabled": false,
      "redirectUris": [
        "http://127.0.0.1:18099/callback",
        "http://[::1]:18099/callback",
        "https://127.0.0.1:18099/callback"
      ],
      "webOrigins": ["+"],
      "frontchannelLogout": true,
      "attributes": {
        "frontchannel.logout.url":              "http://127.0.0.1:18099/oidc/frontchannel-logout",
        "backchannel.logout.url":               "http://127.0.0.1:18099/oidc/backchannel-logout",
        "backchannel.logout.session.required":  "true",
        "backchannel.logout.revoke.offline.tokens": "false",
        "post.logout.redirect.uris":            "http://127.0.0.1:18099/post-logout##http://[::1]:18099/post-logout",
        "pkce.code.challenge.method":           "S256",
        "use.refresh.tokens":                   "true",
        "tls.client.certificate.bound.access.tokens": "false"
      },
      "defaultClientScopes": ["web-origins", "profile", "roles", "email"],
      "optionalClientScopes": ["address", "phone", "offline_access"]
    },
    {
      "clientId": "https://sp.blamejs-test.example",
      "name": "blamejs SAML SP (integration test)",
      "description": "SP entityID for the integration test. Keycloak's SAML response signs the assertion using the realm's RSA-SHA256 key.",
      "enabled": true,
      "protocol": "saml",
      "publicClient": true,
      "redirectUris": [
        "http://127.0.0.1:18099/saml/acs"
      ],
      "frontchannelLogout": false,
      "attributes": {
        "saml.assertion.signature":            "true",
        "saml.server.signature":               "false",
        "saml.signature.algorithm":            "RSA_SHA256",
        "saml.client.signature":               "false",
        "saml.encrypt":                        "false",
        "saml.force.post.binding":             "true",
        "saml_assertion_consumer_url_post":    "http://127.0.0.1:18099/saml/acs",
        "saml_name_id_format":                 "username",
        "saml.authnstatement":                 "true"
      },
      "defaultClientScopes": ["role_list"]
    },
    {
      "clientId": "https://sp-enc.blamejs-test.example",
      "name": "blamejs SAML SP encrypted (integration test)",
      "description": "SP entityID for the EncryptedAssertion decrypt-interop stage. Keycloak encrypts the assertion CEK to saml.encryption.certificate; the integration test overrides that cert with a runtime-generated one (via the admin API) so it holds the matching private key. The algorithm attributes request AES-GCM + RSA-OAEP-SHA256, which Keycloak >= 26.2 honors; Keycloak 26.0.x ignores them and emits aes128-cbc + rsa-oaep-mgf1p(SHA-1), which the framework refuses by design.",
      "enabled": true,
      "protocol": "saml",
      "publicClient": true,
      "redirectUris": [
        "http://127.0.0.1:18099/saml/acs"
      ],
      "frontchannelLogout": false,
      "attributes": {
        "saml.assertion.signature":               "true",
        "saml.server.signature":                  "false",
        "saml.signature.algorithm":               "RSA_SHA256",
        "saml.client.signature":                  "false",
        "saml.encrypt":                           "true",
        "saml.encryption.certificate":            "",
        "saml.encryption.algorithm":              "AES_256_GCM",
        "saml.encryption.keyAlgorithm":           "RSA-OAEP",
        "saml.encryption.digestMethod":           "SHA-256",
        "saml.encryption.maskGenerationFunction": "MGF1-SHA256",
        "saml.force.post.binding":                "true",
        "saml_assertion_consumer_url_post":       "http://127.0.0.1:18099/saml/acs",
        "saml_name_id_format":                    "username",
        "saml.authnstatement":                    "true"
      },
      "defaultClientScopes": ["role_list"]
    }
  ]
}
