# MySQL config for blamejs integration testing.
# Both plain and TLS connections accepted; TLS opt-in via client
# require_secure_transport is OFF so plain still works.

[mysqld]
ssl-ca   = /certs/ca.crt
ssl-cert = /certs/mysql.crt
ssl-key  = /certs/mysql.key
require_secure_transport = OFF
tls_version = TLSv1.3
default_authentication_plugin = caching_sha2_password
bind-address = 0.0.0.0
