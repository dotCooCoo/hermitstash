{
  "_comment": "Vendored dependencies — no npm runtime packages. Use scripts/vendor-update.sh to update.",
  "packages": {
    "@noble/ciphers": {
      "version": "2.2.0",
      "license": "MIT",
      "author": "Paul Miller",
      "source": "https://github.com/paulmillr/noble-ciphers",
      "exports": [
        "xchacha20poly1305"
      ],
      "files": {
        "server": "lib/vendor/noble-ciphers.cjs",
        "browser": "public/js/noble-ciphers.js"
      },
      "bundler": "esbuild --format=cjs/esm --minify --platform=node/browser",
      "bundledAt": "2026-04-23"
    },
    "@noble/hashes": {
      "version": "2.2.0",
      "license": "MIT",
      "author": "Paul Miller",
      "source": "https://github.com/paulmillr/noble-hashes",
      "exports": [
        "shake256"
      ],
      "files": {
        "browser": "public/js/noble-hashes.js"
      },
      "bundler": "esbuild --format=esm --minify --platform=browser",
      "bundledAt": "2026-04-23"
    },
    "@noble/post-quantum": {
      "version": "0.6.1",
      "license": "MIT",
      "author": "Paul Miller",
      "source": "https://github.com/paulmillr/noble-post-quantum",
      "exports": [
        "ml_kem512",
        "ml_kem768",
        "ml_kem1024"
      ],
      "files": {
        "server": "lib/vendor/noble-pq.cjs",
        "browser": "public/js/noble-pq.js"
      },
      "bundler": "esbuild (browser ESM) + manual ESM→CJS conversion (server)",
      "bundledAt": "2026-04-23"
    },
    "@simplewebauthn/server": {
      "version": "13.3.0",
      "license": "MIT",
      "author": "Matthew Miller",
      "source": "https://github.com/MasterKale/SimpleWebAuthn",
      "exports": [
        "generateRegistrationOptions",
        "verifyRegistrationResponse",
        "generateAuthenticationOptions",
        "verifyAuthenticationResponse",
        "MetadataService"
      ],
      "files": {
        "server": "lib/vendor/simplewebauthn-server.cjs"
      },
      "bundler": "esbuild --format=cjs --minify --platform=node --external:crypto --external:node:crypto",
      "bundledAt": "2026-04-09"
    },
    "peculiar-pki": {
      "description": "Bundled @peculiar/x509 + pkijs + reflect-metadata + transitive ASN.1 deps for pure-JS mTLS CA operations (no openssl CLI needed at runtime)",
      "version": "@peculiar/x509@2.0.0 + pkijs@3.4.0",
      "license": "MIT",
      "source": "https://github.com/PeculiarVentures",
      "exports": [
        "x509",
        "pkijs",
        "crypto"
      ],
      "files": {
        "server": "lib/vendor/pki.cjs"
      },
      "includes": [
        "reflect-metadata",
        "pvutils",
        "pvtsutils",
        "asn1js",
        "@peculiar/asn1-schema",
        "@peculiar/asn1-x509",
        "@peculiar/asn1-ecc",
        "@peculiar/asn1-rsa",
        "@peculiar/asn1-cms",
        "@peculiar/asn1-pkcs9"
      ],
      "bundler": "esbuild --format=cjs --minify --platform=node --external:node:crypto",
      "bundledAt": "2026-04-19"
    },
    "argon2": {
      "version": "0.44.0",
      "license": "MIT",
      "author": "Ranieri Althoff",
      "source": "https://github.com/ranisalt/node-argon2",
      "exports": [
        "hash",
        "verify"
      ],
      "files": {
        "server": "lib/vendor/argon2/argon2.cjs",
        "prebuilds": "lib/vendor/argon2/prebuilds/"
      },
      "platforms": [
        "darwin-arm64",
        "darwin-x64",
        "freebsd-arm64",
        "freebsd-x64",
        "linux-arm",
        "linux-arm64",
        "linux-x64",
        "win32-x64"
      ],
      "bundler": "esbuild --format=cjs --platform=node (inlines @phc/format + node-gyp-build)",
      "bundledAt": "2026-04-09"
    }
  }
}
