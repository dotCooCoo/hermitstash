<?xml version="1.0"?>
<Container version="2">
    <Name>hermitstash</Name>
    <Beta>false</Beta>
    <Category>Cloud: Productivity: Tools:</Category>
    <Repository>ghcr.io/dotcoocoo/hermitstash:1</Repository>
    <Registry>https://github.com/dotCooCoo/hermitstash/pkgs/container/hermitstash</Registry>
    <Network>bridge</Network>
    <Privileged>false</Privileged>
    <Shell>sh</Shell>
    <GitHub>https://github.com/dotCooCoo/hermitstash</GitHub>
    <ReadMe>https://github.com/dotCooCoo/hermitstash#readme</ReadMe>
    <Project>https://hermitstash.com</Project>
    <Support>https://github.com/dotCooCoo/hermitstash/issues</Support>
    <TemplateURL>https://raw.githubusercontent.com/dotCooCoo/hermitstash/main/unraid-template.xml</TemplateURL>
    <Overview>Post-quantum encrypted, self-hosted file upload server. All data is sealed with ML-KEM-1024 + XChaCha20-Poly1305. Zero npm dependencies — everything vendored. Features: encrypted file storage, bundles, access codes, teams, WebAuthn passkeys, admin panel, S3 support.</Overview>
    <WebUI>http://[IP]:[PORT:3000]</WebUI>
    <Icon>https://raw.githubusercontent.com/dotCooCoo/hermitstash/main/public/img/icons/icon-512.png</Icon>
    <ExtraParams>--shm-size=256m --init --security-opt=no-new-privileges:true --cap-drop=ALL --cap-add=CHOWN --cap-add=SETUID --cap-add=SETGID --cap-add=DAC_OVERRIDE</ExtraParams>
    <Requires>Requires at least 256MB shared memory (--shm-size=256m) for the in-memory encrypted database.</Requires>

    <!-- Ports -->
    <Config Name="WebUI Port" Target="3000" Default="3000" Mode="tcp" Description="Web interface port." Type="Port" Display="always" Required="true" Mask="false"/>

    <!-- Volumes -->
    <Config Name="Appdata" Target="/app/data" Default="/mnt/user/appdata/hermitstash" Mode="rw" Description="Encrypted database, vault keys, and TLS certs. Back up vault.key — loss means all sealed data is unrecoverable." Type="Path" Display="always" Required="true" Mask="false"/>
    <Config Name="Uploads" Target="/app/uploads" Default="/mnt/user/appdata/hermitstash/uploads" Mode="rw" Description="Uploaded files (local storage only, not needed with S3)." Type="Path" Display="always" Required="true" Mask="false"/>

    <!-- Container user -->
    <Config Name="PUID" Target="PUID" Default="99" Description="User ID for file permissions." Type="Variable" Display="advanced" Required="true" Mask="false"/>
    <Config Name="PGID" Target="PGID" Default="100" Description="Group ID for file permissions." Type="Variable" Display="advanced" Required="true" Mask="false"/>
    <Config Name="UMASK" Target="UMASK" Default="022" Description="File permission mask (022 = 755/644, 000 = 777/666). Use 000 to match Unraid's nobody:users sharing model." Type="Variable" Display="advanced" Required="false" Mask="false"/>
    <Config Name="Timezone" Target="TZ" Default="" Description="Container timezone, e.g. America/New_York." Type="Variable" Display="always" Required="false" Mask="false"/>

    <!-- Core settings -->
    <Config Name="Trust Proxy" Target="TRUST_PROXY" Default="true" Description="Enable if behind a reverse proxy (Nginx Proxy Manager, Traefik, etc.)." Type="Variable" Display="always" Required="false" Mask="false"/>
    <Config Name="Passkey Origin" Target="RP_ORIGIN" Default="" Description="Full URL for passkeys and HSTS, e.g. https://files.example.com. Required if using a domain." Type="Variable" Display="always" Required="false" Mask="false"/>

    <!-- Auth -->
    <Config Name="Local Auth" Target="LOCAL_AUTH" Default="true" Description="Enable username/password login." Type="Variable" Display="always" Required="false" Mask="false"/>
    <Config Name="Registration Open" Target="REGISTRATION_OPEN" Default="true" Description="Allow new user registration." Type="Variable" Display="always" Required="false" Mask="false"/>
    <Config Name="Public Upload" Target="PUBLIC_UPLOAD" Default="true" Description="Allow anonymous file uploads." Type="Variable" Display="always" Required="false" Mask="false"/>
    <Config Name="Passkeys" Target="PASSKEY_ENABLED" Default="true" Description="Enable WebAuthn passkey authentication." Type="Variable" Display="always" Required="false" Mask="false"/>

    <!-- Google OAuth -->
    <Config Name="Google Client ID" Target="GOOGLE_CLIENT_ID" Default="" Description="Google OAuth client ID (leave empty to disable)." Type="Variable" Display="advanced" Required="false" Mask="false"/>
    <Config Name="Google Client Secret" Target="GOOGLE_CLIENT_SECRET" Default="" Description="Google OAuth client secret." Type="Variable" Display="advanced" Required="false" Mask="true"/>

    <!-- SMTP -->
    <Config Name="SMTP Host" Target="SMTP_HOST" Default="" Description="SMTP server hostname, e.g. smtp.gmail.com (leave empty to disable email)." Type="Variable" Display="advanced" Required="false" Mask="false"/>
    <Config Name="SMTP Port" Target="SMTP_PORT" Default="587" Description="SMTP server port." Type="Variable" Display="advanced" Required="false" Mask="false"/>
    <Config Name="SMTP User" Target="SMTP_USER" Default="" Description="SMTP username." Type="Variable" Display="advanced" Required="false" Mask="false"/>
    <Config Name="SMTP Password" Target="SMTP_PASS" Default="" Description="SMTP password." Type="Variable" Display="advanced" Required="false" Mask="true"/>
    <Config Name="SMTP From" Target="SMTP_FROM" Default="" Description="From address for outgoing email, e.g. noreply@example.com." Type="Variable" Display="advanced" Required="false" Mask="false"/>

    <!-- Storage -->
    <Config Name="Storage Backend" Target="STORAGE_BACKEND" Default="local" Description="File storage backend (local or s3)." Type="Variable" Display="advanced" Required="false" Mask="false"/>
    <Config Name="Max File Size" Target="MAX_FILE_SIZE" Default="104857600" Description="Maximum upload size in bytes (default 100MB)." Type="Variable" Display="advanced" Required="false" Mask="false"/>

    <!-- S3 (advanced) -->
    <Config Name="S3 Bucket" Target="S3_BUCKET" Default="" Description="S3 bucket name (only when Storage Backend is s3)." Type="Variable" Display="advanced" Required="false" Mask="false"/>
    <Config Name="S3 Region" Target="S3_REGION" Default="" Description="S3 region, e.g. us-east-1." Type="Variable" Display="advanced" Required="false" Mask="false"/>
    <Config Name="S3 Endpoint" Target="S3_ENDPOINT" Default="" Description="Custom S3 endpoint for R2/MinIO/Backblaze." Type="Variable" Display="advanced" Required="false" Mask="false"/>
    <Config Name="S3 Access Key" Target="S3_ACCESS_KEY" Default="" Description="S3 access key ID." Type="Variable" Display="advanced" Required="false" Mask="false"/>
    <Config Name="S3 Secret Key" Target="S3_SECRET_KEY" Default="" Description="S3 secret access key." Type="Variable" Display="advanced" Required="false" Mask="true"/>

    <!-- Backup schedule (advanced; admin UI also exposes these) -->
    <Config Name="Backup Time of Day" Target="BACKUP_TIME_OF_DAY" Default="03:00" Description="HH:MM (24-hour) when daily/weekly backups run. Anchored to Backup Timezone." Type="Variable" Display="advanced" Required="false" Mask="false"/>
    <Config Name="Backup Timezone" Target="BACKUP_TIMEZONE" Default="" Description="IANA timezone name (e.g. America/New_York). Empty = follows the container Timezone (TZ) setting above." Type="Variable" Display="advanced" Required="false" Mask="false"/>

    <!-- Vault passphrase protection (opt-in, v1.9+) -->
    <!-- Default is disabled. When enabled, the vault key is encrypted at rest with an Argon2id-derived passphrase. -->
    <!-- ⚠ LOSS of passphrase = LOSS of all encrypted data. HermitStash has no recovery mechanism. -->
    <!-- Enable only after: (1) storing the passphrase in a password manager, AND (2) running scripts/vault-passphrase-setup.js -->
    <!-- via `docker exec -it hermitstash node scripts/vault-passphrase-setup.js` to migrate the existing plaintext vault.key. -->
    <Config Name="Vault Passphrase Mode" Target="VAULT_PASSPHRASE_MODE" Default="" Description="Set to 'required' to enable passphrase-encrypted vault.key. Leave empty (default) for plaintext vault.key protected by filesystem permissions only. See README 'Passphrase protection (opt-in)' — LOSS OF PASSPHRASE = LOSS OF DATA." Type="Variable" Display="advanced" Required="false" Mask="false"/>
    <Config Name="Vault Passphrase" Target="VAULT_PASSPHRASE" Default="" Description="The passphrase itself — only set when Vault Passphrase Mode is 'required'. Store it in a password manager BEFORE entering it here; there is no recovery if lost." Type="Variable" Display="advanced" Required="false" Mask="true"/>
</Container>
