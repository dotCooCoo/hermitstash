# ============================================================
# HermitStash Environment Variables
# Copy to .env or configure in Coolify UI
# All settings also configurable from Admin > Settings panel
# ============================================================

# ---- General ----
NODE_ENV=production
PORT=3000
SITE_NAME=HermitStash
# Set to "true" when behind a reverse proxy (nginx, Cloudflare, Coolify)
TRUST_PROXY=true

# ---- Authentication ----
# Enable local email/password login
LOCAL_AUTH=true
# Allow new users to self-register
REGISTRATION_OPEN=true
# Allow anonymous file uploads (no login required)
PUBLIC_UPLOAD=true

# ---- Passkey / WebAuthn ----
PASSKEY_ENABLED=true
# Your domain name (no protocol) — e.g. hermitstash.example.com
RP_ID=hermitstash.example.com
# Full origin URL — e.g. https://hermitstash.example.com
RP_ORIGIN=https://hermitstash.example.com

# ---- Google OAuth (leave empty to disable) ----
# Create credentials at https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ---- Email / SMTP (leave empty to disable) ----
# Examples: smtp.gmail.com, smtp.mailgun.org, email-smtp.us-east-1.amazonaws.com
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
# Sender address — e.g. noreply@hermitstash.example.com
SMTP_FROM=
# Require email verification before login
EMAIL_VERIFICATION=false

# ---- Storage ----
# "local" for disk, "s3" for S3-compatible (AWS, MinIO, R2, Backblaze)
STORAGE_BACKEND=local
UPLOAD_DIR=/app/uploads
# Max file size in bytes (default 100MB)
MAX_FILE_SIZE=104857600

# ---- S3 (only when STORAGE_BACKEND=s3) ----
S3_BUCKET=
# e.g. us-east-1, eu-west-1, auto
S3_REGION=
# Custom endpoint for S3-compatible services (MinIO, R2, Backblaze)
# e.g. https://s3.us-east-1.amazonaws.com, https://<account>.r2.cloudflarestorage.com
S3_ENDPOINT=
S3_ACCESS_KEY=
S3_SECRET_KEY=
