# Persistent data (mounted as volumes, never baked into image)
data/
uploads/

# Git
.git/
.gitignore
.gitattributes

# GitHub metadata (not needed in runtime image)
.github/

# Dev/build tools
node_modules/
tests/
coverage/
scripts/
template/
build/
deploy/

# Dot-directories (IDE, tool configs, local state)
.*
!.gitkeep

# Docker build files (no need to include themselves)
Dockerfile
docker-compose.yml
docker-compose.*.yml

# Docs (excluded by *.md, listed explicitly for clarity)
*.md

# Secrets / env
.env*

# Logs / temp
*.log
*.bak
*.tmp
*.swp

# Non-Linux argon2 prebuilds (dead weight in Linux containers)
lib/vendor/argon2/prebuilds/darwin-arm64/
lib/vendor/argon2/prebuilds/darwin-x64/
lib/vendor/argon2/prebuilds/freebsd-arm64/
lib/vendor/argon2/prebuilds/freebsd-x64/
lib/vendor/argon2/prebuilds/win32-x64/

# blamejs vendor reference material — examples + tests + docs are not
# part of HermitStash's runtime; excluding them strips ~15 MB and keeps
# Trivy from scanning blamejs's example Dockerfile (which uses a base
# image without a USER directive — an upstream example concern, not
# ours).
lib/vendor/blamejs/examples/
lib/vendor/blamejs/test/
lib/vendor/blamejs/docs/
lib/vendor/blamejs/CHANGELOG.md
lib/vendor/blamejs/README.md
lib/vendor/blamejs/SECURITY.md
lib/vendor/blamejs/.github/
lib/vendor/blamejs/scripts/
